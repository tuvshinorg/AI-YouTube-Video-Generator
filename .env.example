# ─────────────────────────────────────────────────────────────────────────────
# AI YouTube Video Generator — user configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path to this repository on your machine.
# Leave empty to auto-detect (directory of pipeline.py).
BASE_DIR=

# ── LLM (llama.cpp) ──────────────────────────────────────────────────────────
# Path to your GGUF model file.  Download example:
#   huggingface-cli download bartowski/Llama-3.2-3B-Instruct-GGUF \
#       Llama-3.2-3B-Instruct-Q6_K.gguf --local-dir ./models
LLAMA_MODEL_PATH=./models/Llama-3.2-3B-Instruct-Q6_K.gguf

# Context window size in tokens.
LLAMA_N_CTX=4096

# Number of model layers to offload to GPU.
# -1 = all layers on GPU (fastest), 0 = CPU only.
LLAMA_N_GPU=-1

# Show llama.cpp token-by-token output (true/false).
LLAMA_VERBOSE=false

# ── Image generation (HuggingFace Flux) ──────────────────────────────────────
# Any FLUX-compatible model repo on HuggingFace.  Examples:
#   black-forest-labs/FLUX.1-dev
#   black-forest-labs/FLUX.1-schnell
#   enhanceaiteam/Flux-Uncensored-V2
FLUX_MODEL_ID=enhanceaiteam/Flux-Uncensored-V2

# Offload model layers to CPU when not in use (saves VRAM).
# Set to false only if you have ≥24 GB VRAM.
FLUX_CPU_OFFLOAD=true

# Output image size (vertical/portrait for YouTube Shorts).
FLUX_WIDTH=540
FLUX_HEIGHT=960
FLUX_STEPS=20
FLUX_GUIDANCE=3.5

# ── Text-to-speech ────────────────────────────────────────────────────────────
# Any voice supported by edge-tts.  Run `edge-tts --list-voices` to see all.
TTS_VOICE=en-US-AvaNeural

# ── YouTube upload ────────────────────────────────────────────────────────────
# Leave these as-is unless you moved the credential files.
# client_secret.json and credentials.storage must be placed in BASE_DIR.
# Follow docs/youtube-auth.md to generate them.
YT_CLIENT_SECRET=client_secret.json
YT_CREDENTIALS=credentials.storage
